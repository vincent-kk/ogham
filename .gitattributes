* text=auto eol=lf
*.ts  linguist-detectable
*.mjs linguist-detectable

# Rule doc templates must stay LF so sync-rule-hashes.mjs produces deterministic hashes across OS
plugins/filid/templates/rules/*.md text eol=lf

# Windows .cmd / .bat shims MUST be CRLF — cmd.exe rejects LF-only batch files
*.cmd text eol=crlf
*.bat text eol=crlf

# Compiled plugin distribution trees are generated (see @ogham/plugin-compiler).
# Mark generated so reviews collapse the diff; edit definitions/, not targets/.
plugins/*/targets/** linguist-generated

