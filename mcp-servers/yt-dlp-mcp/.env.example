# @ogham/yt-dlp-mcp — environment configuration
# All variables are optional. Copy to `.env` only for local development;
# MCP hosts normally pass these via the server's `env` block.

# ── Paths (ADR-9: single ~/.yt-dlp tree) ──────────────────────────────
# Root for the shared binary, temp workspace, and downloads.
# YTDLP_HOME=~/.yt-dlp
# Override only the final downloads directory.
# YTDLP_DOWNLOADS_DIR=~/.yt-dlp/downloads

# ── Binary acquisition / supply chain ─────────────────────────────────
# Only adopt yt-dlp releases older than this many days (cooldown pin).
# YTDLP_COOLDOWN_DAYS=3
# Refresh the cached binary after this many days.
# YTDLP_REFRESH_DAYS=7
# Pin to an exact yt-dlp release tag, bypassing cooldown selection.
# YTDLP_PINNED_VERSION=2025.01.01

# ── Extraction limits / concurrency / pacing ──────────────────────────
# Concurrency and the request-pacing intervals below adapt to proxy state by
# default; set any of them explicitly to override the adaptive value.
#
#   proxy state   maxConcurrency   requestIntervalMs   subtitleIntervalMs
#   ---------------------------------------------------------------------
#   none          1                1500                4000
#   single        2                750                 2000
#   pool (N)      min(N, 8)        0                   250
#
# YTDLP_MAX_CONCURRENCY=2
# Minimum spacing (ms) between dispatched yt-dlp calls (light/metadata ops).
# YTDLP_REQUEST_INTERVAL_MS=750
# Minimum spacing (ms) between subtitle/transcript calls (timedtext is the
# most aggressively rate-limited endpoint, so it is paced separately).
# YTDLP_SUBTITLE_INTERVAL_MS=2000
# YTDLP_TIMEOUT_MS=90000
# YTDLP_CHARACTER_LIMIT=25000
# YTDLP_MAX_TRANSCRIPT_LENGTH=50000
# Default caption language for transcript/subtitles when the caller omits one.
# Only ONE language is fetched per call (timedtext is rate-limited), so set this
# to your primary content language to avoid empty results. Default: en.
# YTDLP_DEFAULT_SUB_LANG=ko

# ── Localization ──────────────────────────────────────────────────────
# Preferred interface language for metadata/titles. YouTube serves translated
# titles by language; this returns originals in your locale. Applies to
# search / playlist / metadata only — never to subtitle fetches, so it adds no
# rate-limit cost. Unset = yt-dlp default. e.g. ko, en, ja.
# YTDLP_LANG=ko

# ── Optional tool toggles (default tools are always on) ────────────────
# Set to 1 to register the matching opt-in tool(s). Off by default.
# YTDLP_ENABLE_SUBTITLES=1
# YTDLP_ENABLE_METADATA_SUMMARY=1
# YTDLP_ENABLE_COMMENTS=1
# YTDLP_ENABLE_COMMENTS_SUMMARY=1
# YTDLP_ENABLE_CHAPTERS=1
# YTDLP_ENABLE_HEATMAP=1
# YTDLP_ENABLE_THUMBNAIL=1
# YTDLP_ENABLE_DOWNLOAD=1
# YTDLP_ENABLE_PLAYLIST=1
# Convenience: register every tool at once.
# YTDLP_ENABLE_ALL=1

# ── Evasion (opt-in; review platform ToS / local law) ─────────────────
# PRIMARY mitigation for 429 / rate limits: rate limits are IP-based, so the
# most effective fix is rotating across many IPs. A comma-separated pool is
# round-robined per request; it also relaxes the adaptive pacing above.
# YTDLP_PROXY_POOL=http://a:1@h1:8080,http://a:1@h2:8080,http://a:1@h3:8080
# Single static proxy (used when no pool is set).
# YTDLP_PROXY=socks5://127.0.0.1:1080
#
# Cookies are AUTH GATES ONLY (age-restricted / members-only / sign-in walls).
# They rarely help with subtitle (timedtext) 429s — use a proxy pool for those.
# Read cookies from a local browser profile: BROWSER[:PROFILE][::CONTAINER]
# YTDLP_COOKIES_FROM_BROWSER=chrome
# Path to a Netscape-format cookies file (takes precedence over browser).
# YTDLP_COOKIES_FILE=/path/to/cookies.txt

# ── Logging ───────────────────────────────────────────────────────────
# trace | debug | info | warn | error | fatal | silent
# YTDLP_LOG_LEVEL=info
