{
  "name": "@ogham/yt-dlp-mcp",
  "version": "0.0.4",
  "description": "MCP server that extracts YouTube (and yt-dlp-supported) transcripts, metadata, comments, chapters, and media — auto-acquires a cooldown-pinned, checksum-verified yt-dlp binary for zero system install.",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "yt-dlp",
    "youtube",
    "transcript",
    "subtitles",
    "metadata",
    "llm"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/vincent-kk/ogham.git",
    "directory": "mcp-servers/yt-dlp-mcp"
  },
  "license": "MIT",
  "author": {
    "name": "Vincent K. Kelvin",
    "email": "lunox273@gmail.com"
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": "dist/index.js",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "yarn clean && tsc -p tsconfig.build.json && tsc-alias -p tsconfig.build.json && node scripts/build-bundle.mjs && node scripts/finalize-bin.mjs",
    "clean": "rm -rf dist .tsbuildinfo",
    "dev": "tsc -p tsconfig.build.json --watch",
    "format": "prettier --write \"src/**/*.ts\" \"*.{json,md}\"",
    "publish:npm": "yarn npm publish --access public",
    "start": "node dist/index.js",
    "test": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "RUN_NETWORK_TESTS=1 RUN_BINARY_TESTS=1 vitest run",
    "test:run": "vitest run",
    "typecheck": "tsc -p tsconfig.build.json --noEmit",
    "version:major": "yarn version major",
    "version:minor": "yarn version minor",
    "version:patch": "yarn version patch"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "~1.22.0",
    "execa": "^9.5.0",
    "p-limit": "^6.2.0",
    "pino": "^9.5.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@vitest/coverage-v8": "^4.1.10",
    "esbuild": "^0.24.0",
    "tsc-alias": "^1.8.17",
    "typescript": "^5.7.2",
    "vitest": "^4.1.10"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
