{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "FILE=$(jq -r '.tool_input.file_path // .tool_input.notebook_path // empty'); [ -n \"$FILE\" ] && [ -f \"$FILE\" ] && cd \"$CLAUDE_PROJECT_DIR\" && \"$CLAUDE_PROJECT_DIR/node_modules/.bin/prettier\" --write --ignore-unknown --log-level=warn \"$FILE\" >&2 || true"
          }
        ]
      }
    ]
  }
}
