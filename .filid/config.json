{
  "version": "1.0",
  "language": "ko",
  "rules": {
    "naming-convention": {
      "enabled": true,
      "severity": "warning"
    },
    "organ-no-intentmd": {
      "enabled": true,
      "severity": "error"
    },
    "index-barrel-pattern": {
      "enabled": true,
      "severity": "warning"
    },
    "module-entry-point": {
      "enabled": true,
      "severity": "warning"
    },
    "max-depth": {
      "enabled": true,
      "severity": "error"
    },
    "circular-dependency": {
      "enabled": true,
      "severity": "error"
    },
    "pure-function-isolation": {
      "enabled": true,
      "severity": "error"
    },
    "zero-peer-file": {
      "enabled": true,
      "severity": "warning"
    }
  },
  "additional-allowed": [
    "version.ts",
    "hooks.json",
    "SKILL.md",
    "DETAIL.md",
    "INTENT.md",
    "README.md",
    "README-ko_kr.md",
    "CLAUDE.md",
    "package.json",
    "tsconfig.json",
    "tsconfig.build.json",
    "tsconfig.tsbuildinfo",
    "tsconfig.build.tsbuildinfo",
    "vitest.config.ts",
    "vitest.setup.ts",
    "vitest.e2e.config.ts",
    "vitest.e2e.setup.ts",
    "vitest.e2e.globalSetup.ts",
    "index.html"
  ]
}
