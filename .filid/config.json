{
  "version": "1.0",
  "rules": {
    "naming-convention": {
      "enabled": true,
      "severity": "warning"
    },
    "organ-no-intentmd": {
      "enabled": true,
      "severity": "error"
    },
    "index-barrel-pattern": {
      "enabled": true,
      "severity": "warning"
    },
    "module-entry-point": {
      "enabled": true,
      "severity": "warning"
    },
    "max-depth": {
      "enabled": true,
      "severity": "error"
    },
    "circular-dependency": {
      "enabled": true,
      "severity": "error"
    },
    "pure-function-isolation": {
      "enabled": true,
      "severity": "error"
    },
    "zero-peer-file": {
      "enabled": true,
      "severity": "warning"
    }
  },
  "language": "ko",
  "additional-allowed": [
    "version.ts",
    "hooks.json",
    "SKILL.md",
    "DETAIL.md",
    "INTENT.md",
    "README.md",
    "README-ko_kr.md",
    "CLAUDE.md",
    "package.json",
    "tsconfig.json",
    "tsconfig.build.json",
    "tsconfig.tsbuildinfo",
    "tsconfig.build.tsbuildinfo",
    "vitest.config.ts",
    "vitest.setup.ts",
    "vitest.e2e.config.ts",
    "vitest.e2e.setup.ts",
    "vitest.e2e.globalSetup.ts",
    "playwright.config.ts",
    "index.html",
    {
      "basename": "setup.entry.ts",
      "paths": [
        "**/plugins/filid/src/hooks/setup"
      ]
    },
    {
      "basename": "preToolUse.entry.ts",
      "paths": [
        "**/plugins/filid/src/hooks/preToolUse"
      ]
    },
    {
      "basename": "agentEnforcer.entry.ts",
      "paths": [
        "**/plugins/filid/src/hooks/agentEnforcer"
      ]
    },
    {
      "basename": "userPromptSubmit.entry.ts",
      "paths": [
        "**/plugins/filid/src/hooks/userPromptSubmit"
      ]
    }
  ],
  "additional-route-patterns": [
    "^_shared$",
    "^__tests__$"
  ]
}
