{
  "name": "@ogham/plugin-compiler",
  "version": "0.0.0",
  "private": true,
  "description": "Internal to the ogham monorepo — generates Codex / Antigravity adapter files (in place) from each plugin's Claude artifacts",
  "license": "MIT",
  "author": {
    "name": "Vincent K. Kelvin"
  },
  "type": "module",
  "scripts": {
    "format": "prettier --write \"src/**/*.ts\" \"*.{json,md}\"",
    "sync": "tsx src/main.ts sync",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
