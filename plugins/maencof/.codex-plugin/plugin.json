{
  "name": "maencof",
  "version": "0.9.6",
  "description": "Personal knowledge space manager with markdown-based knowledge graph, spreading activation search, and memory lifecycle management",
  "author": {
    "name": "Vincent K. Kelvin"
  },
  "repository": "https://github.com/vincent-kk/ogham",
  "homepage": "https://github.com/vincent-kk/ogham/tree/main/plugins/maencof",
  "license": "MIT",
  "keywords": [
    "claude-code",
    "plugin",
    "knowledge-graph",
    "memory",
    "spreading-activation",
    "markdown"
  ],
  "skills": "./skills/",
  "hooks": "./hooks/hooks.json",
  "mcpServers": {
    "maencof": {
      "command": "node",
      "args": [
        "bridge/mcp-server.cjs"
      ],
      "env": {
        "OGHAM_HOST": "codex"
      }
    }
  }
}
