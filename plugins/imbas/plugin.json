{
  "name": "imbas",
  "version": "0.5.1",
  "description": "Imbas — issue pipeline planning plugin for Claude Code. Validates planning documents, splits them into Stories, generates Subtasks, and batch-creates issues on Jira, GitHub, or local markdown.",
  "author": {
    "name": "Vincent K. Kelvin"
  },
  "repository": "https://github.com/vincent-kk/ogham",
  "homepage": "https://github.com/vincent-kk/ogham/tree/main/plugins/imbas",
  "license": "MIT",
  "keywords": [
    "claude-code",
    "plugin"
  ],
  "skills": "./skills/",
  "hooks": "./hooks/hooks.json",
  "mcpServers": {
    "imbas": {
      "command": "node",
      "args": [
        "bridge/mcp-server.cjs"
      ],
      "cwd": ".",
      "env": {
        "OGHAM_HOST": "codex"
      }
    }
  }
}
