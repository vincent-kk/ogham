{
  "name": "@ogham/filid",
  "version": "0.7.6",
  "description": "FCA-AI rule enforcement plugin for Claude Code agent workflows",
  "keywords": [
    "claude-code",
    "plugin",
    "fca-ai",
    "fractal",
    "context-architecture"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/vincent-kk/ogham.git",
    "directory": "plugins/filid"
  },
  "license": "MIT",
  "author": {
    "name": "Vincent K. Kelvin",
    "email": "lunox273@gmail.com"
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "agents",
    "bridge",
    "libs",
    "hooks",
    "skills",
    "templates",
    "public",
    ".claude-plugin",
    "plugin.json",
    ".codex-plugin",
    ".mcp.json",
    "mcp_config.json",
    "hooks.json",
    "README.md"
  ],
  "scripts": {
    "bench": "vitest bench",
    "bench:run": "vitest bench --run",
    "build": "yarn clean && yarn version:sync && yarn build:rules && yarn build:pages && yarn build:compile && yarn build:mcp && yarn build:hooks && yarn build:compile-plugin",
    "build:rules": "node scripts/syncRuleHashes.mjs",
    "build:pages": "node scripts/buildSettingsHtml.mjs",
    "build:compile": "tsc -p tsconfig.build.json",
    "build:mcp": "node scripts/buildMcpServer.mjs",
    "build:hooks": "node scripts/buildHooks.mjs",
    "build:compile-plugin": "node --import tsx ../../tools/plugin-compiler/src/main.ts sync .",
    "build:plugin": "yarn build:pages && yarn build:mcp && yarn build:hooks",
    "clean": "rm -rf bridge",
    "dev": "tsc --watch",
    "format": "prettier --write \"src/**/*.ts\" \"*.{json,mjs,md}\"",
    "test": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "yarn build:pages && playwright test",
    "test:run": "vitest run",
    "typecheck": "tsc --noEmit",
    "version:major": "yarn version major",
    "version:minor": "yarn version minor",
    "version:patch": "yarn version patch",
    "version:sync": "node ../../scripts/inject-version.mjs"
  },
  "dependencies": {
    "@ast-grep/napi": "^0.42.0",
    "@modelcontextprotocol/sdk": "~1.22.0",
    "fast-glob": "^3.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@ogham/cross-platform": "workspace:^",
    "@ogham/http-guard": "workspace:^",
    "@ogham/session-finalizer": "workspace:^",
    "@playwright/test": "^1.61.0",
    "@types/node": "^20.11.0",
    "@vitest/coverage-v8": "^4.1.10",
    "esbuild": "^0.24.0",
    "typescript": "^5.7.2",
    "vitest": "^4.1.10"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
