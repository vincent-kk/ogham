{
  "name": "@ogham/dalen",
  "version": "0.0.0",
  "description": "Dalen — render Claude markdown reports as a readable browser page with line-anchored feedback back to Claude",
  "keywords": [
    "claude-code",
    "plugin",
    "markdown",
    "report",
    "viewer",
    "feedback"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/vincent-kk/ogham.git",
    "directory": "plugins/dalen"
  },
  "license": "MIT",
  "author": {
    "name": "Vincent K. Kelvin",
    "email": "lunox273@gmail.com"
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "bridge",
    "skills",
    ".claude-plugin",
    ".mcp.json",
    "README.md"
  ],
  "scripts": {
    "build": "yarn clean && yarn version:sync && tsc -p tsconfig.build.json",
    "clean": "rm -rf bridge dist",
    "dev": "tsc --watch",
    "format": "prettier --write \"src/**/*.ts\" \"*.{json,mjs,md}\"",
    "test": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:run": "vitest run",
    "typecheck": "tsc --noEmit",
    "version:major": "yarn version major",
    "version:minor": "yarn version minor",
    "version:patch": "yarn version patch",
    "version:sync": "node ../../scripts/inject-version.mjs"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "~1.22.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@vitest/coverage-v8": "^3.2.4",
    "esbuild": "^0.24.0",
    "typescript": "^5.7.2",
    "vitest": "^4.1.2"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
