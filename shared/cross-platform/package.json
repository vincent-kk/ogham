{
  "name": "@ogham/cross-platform",
  "version": "0.0.0",
  "private": true,
  "description": "ogham 모노레포 내부 전용 — Windows-Unix 호환성 어댑터 (spawn, paths, env, eol, binaries, hooks, shim)",
  "license": "MIT",
  "author": {
    "name": "Vincent K. Kelvin",
    "email": "lunox273@gmail.com"
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "yarn clean && tsc -p tsconfig.build.json",
    "clean": "rm -rf dist tsconfig.tsbuildinfo tsconfig.build.tsbuildinfo",
    "dev": "tsc --watch",
    "format": "prettier --write \"src/**/*.ts\" \"*.{json,md}\"",
    "test": "vitest",
    "test:run": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/cross-spawn": "^6.0.6",
    "@types/node": "^20.11.0",
    "@types/which": "^3.0.4",
    "cross-spawn": "^7.0.6",
    "env-paths": "^3.0.0",
    "typescript": "^5.7.2",
    "vitest": "^4.1.2",
    "which": "^4.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
