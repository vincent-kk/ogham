{
  "name": "ogham",
  "version": "0.0.0",
  "private": true,
  "description": "ogham monorepo — Claude Code plugins and developer tools",
  "repository": {
    "type": "git",
    "url": "https://github.com/vincent-kk/ogham.git",
    "owner": "vincent-kk"
  },
  "license": "MIT",
  "type": "module",
  "workspaces": [
    "mcp-servers/*",
    "plugins/*",
    "shared/*"
  ],
  "scripts": {
    "atlassian": "yarn workspace @ogham/atlassian",
    "build:all": "node scripts/build-all.mjs",
    "cennad": "yarn workspace @ogham/cennad",
    "clean": "yarn workspaces foreach -A exec rm -rf dist .tsbuildinfo",
    "crossPlatform": "yarn workspace @ogham/cross-platform",
    "deilen": "yarn workspace @ogham/deilen",
    "entrez": "yarn workspace @ogham/entrez",
    "filid": "yarn workspace @ogham/filid",
    "imbas": "yarn workspace @ogham/imbas",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "maencof": "yarn workspace @ogham/maencof",
    "maencof-lens": "yarn workspace @ogham/maencof-lens",
    "prawf": "yarn workspace @ogham/prawf",
    "publish:all": "yarn workspaces foreach -A --no-private run publish:npm",
    "rStatistics": "yarn workspace @ogham/r-statistics",
    "run:all": "yarn workspaces foreach -A --topological-dev run",
    "sort:packages": "npx sort-package-json '**/package.json'",
    "tag:packages": "./scripts/tag-packages.sh",
    "test": "vitest",
    "test:run": "vitest run",
    "typecheck": "node scripts/typecheck-all.mjs",
    "yt-dlp-mcp": "yarn workspace @ogham/yt-dlp-mcp"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^10.1.0",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "prettier": "^3.8.1",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.10"
  },
  "packageManager": "yarn@4.12.0",
  "engines": {
    "node": ">=20.0.0"
  }
}
